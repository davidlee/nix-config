#!/usr/bin/env python3
"""Panopticon health checks for sleipnir-doctor.

Checks service health, raw event freshness (catches dead producers),
and segment/histogram currency (catches broken segmentizer).
"""

import json
import os
import subprocess
import time
from datetime import date, datetime, timedelta, timezone
from pathlib import Path

STATE = Path.home() / ".local" / "state" / "behaviour"
RAW = STATE / "raw"
SEGMENTS = STATE / "segments"
HISTOGRAMS = STATE / "histograms"

OK, WARN = "OK", "WARN"
CAT = "Panopticon"

# Keys are RAW filename stems (freshest_today reads raw/<key>-*.jsonl);
# `prefix` is the SEGMENT stem (check_segments reads segments/<prefix>-*.jsonl).
# The two namespaces differ: the compositor-neutral watcher writes
# raw/desktop-*.jsonl but its segments are still named focus-* (SL-004).
SOURCES = {
  "desktop": {"warn_minutes": 30, "prefix": "focus"},
  "firefox": {"warn_minutes": 240, "prefix": "browser"},
}


def service_active(unit):
  try:
    r = subprocess.run(
      ["systemctl", "--user", "is-active", unit],
      capture_output=True, text=True, timeout=5,
    )
    return r.stdout.strip() == "active"
  except (FileNotFoundError, subprocess.TimeoutExpired):
    return False


def file_age_minutes(path):
  try:
    return (time.time() - os.path.getmtime(path)) / 60
  except OSError:
    return None


def fmt_age(minutes):
  if minutes is None:
    return "no file"
  if minutes < 1:
    return "<1 min ago"
  if minutes < 60:
    return f"{minutes:.0f} min ago"
  return f"{minutes / 60:.1f} h ago"


def freshest_today(source):
  """Age of the freshest raw file dated *today*, local or UTC.

  Raw files are bucketed on the day as the producer stamped it. The desktop
  watcher stamps local-offset, firefox likewise post-fix — but a producer stamping
  UTC `Z` buckets on the UTC day, which lags the local day by the offset (e.g.
  until 10:00 in AEST). Checking both dates means a wrong-tz producer reports
  its real freshness instead of a phantom "no events today" each morning.
  """
  days = {date.today().isoformat(), datetime.now(timezone.utc).date().isoformat()}
  ages = [a for a in (file_age_minutes(RAW / f"{source}-{d}.jsonl") for d in days)
          if a is not None]
  return min(ages) if ages else None


def check_services():
  results = []
  # Timers (not the oneshot .services — those sit inactive between runs and
  # would false-WARN). panopticon-sway.service is the long-running watcher.
  for unit in ("panopticon-sway.service", "panopticon-segmentize.timer",
               "panopticon-git.timer"):
    active = service_active(unit)
    results.append({
      "category": CAT, "name": unit,
      "status": OK if active else WARN,
      "detail": "active" if active else "not running",
    })
  return results


def check_raw_freshness():
  ages = {}
  for source in SOURCES:
    ages[source] = freshest_today(source)

  # Primary "is the machine even in use" signal — the compositor watcher.
  desktop_fresh = ages.get("desktop") is not None and ages["desktop"] < 30

  results = []
  for source, cfg in SOURCES.items():
    age = ages[source]
    if age is None:
      status = WARN
      detail = "no events today"
    elif age > cfg["warn_minutes"]:
      status = WARN
      detail = fmt_age(age)
    else:
      status = OK
      detail = fmt_age(age)

    if status == WARN and source != "desktop" and not desktop_fresh:
      detail += " (desktop also stale)"

    results.append({
      "category": CAT,
      "name": f"raw/{source} freshness",
      "status": status, "detail": detail,
    })
  return results


def check_segments():
  yesterday = (date.today() - timedelta(days=1)).isoformat()
  results = []
  for source, cfg in SOURCES.items():
    prefix = cfg["prefix"]
    path = SEGMENTS / f"{prefix}-{yesterday}.jsonl"
    exists = path.exists()
    results.append({
      "category": CAT,
      "name": f"segments/{prefix} (yesterday)",
      "status": OK if exists else WARN,
      "detail": "present" if exists else "missing",
    })
  return results


def dir_size_mb(path):
  if not path.is_dir():
    return 0
  total = sum(f.stat().st_size for f in path.rglob("*") if f.is_file())
  return total / 1024 / 1024


def check_storage():
  tiers = {"raw": RAW, "segments": SEGMENTS, "histograms": HISTOGRAMS}
  parts = []
  total = 0
  for name, path in tiers.items():
    mb = dir_size_mb(path)
    total += mb
    parts.append(f"{name} {mb:.0f}")
  detail = f"{total:.0f} MB ({', '.join(parts)})"
  status = OK
  if total > 1024:
    status = WARN
  return {
    "category": CAT, "name": "storage",
    "status": status, "detail": detail,
  }


def check_watcher_journal():
  # journalctl target stays panopticon-sway.service — the unit name is a
  # retained stable alias (SL-004 D4); it runs the compositor-neutral watcher.
  name = "watcher journal (24h)"
  try:
    r = subprocess.run(
      ["journalctl", "--user-unit=panopticon-sway.service",
       "--since", "24 hours ago", "--no-pager", "-q"],
      capture_output=True, text=True, timeout=10,
    )
    if r.returncode != 0:
      return {"category": CAT, "name": name,
              "status": WARN, "detail": "journalctl failed"}
    lines = r.stdout.strip().splitlines()
    low = [l.lower() for l in lines]
    errors = [l for l in low if "error" in l]
    reconnects = [l for l in low if "reconnect" in l]
    # A connected-but-broken watcher logs WARNING-level disconnects — e.g.
    # "sway disconnected: Failed to retrieve the i3 or sway IPC socket path" —
    # which carry no ERROR/reconnect token. The real outage we hit slipped
    # through as `clean` while service-active + raw-freshness also read green.
    # Match the actual failure vocabulary so a broken watcher trips a WARN.
    disconnects = [l for l in low
                   if "disconnect" in l or "failed to" in l or "ipc socket" in l]
    warnings = [l for l in low if "warning" in l]
    parts = []
    if reconnects:
      parts.append(f"{len(reconnects)} reconnects")
    if disconnects:
      parts.append(f"{len(disconnects)} disconnects")
    if errors:
      parts.append(f"{len(errors)} errors")
    if warnings and not (errors or disconnects):
      parts.append(f"{len(warnings)} warnings")
    if not parts:
      return {"category": CAT, "name": name,
              "status": OK, "detail": f"{len(lines)} lines, clean"}
    status = WARN if errors or disconnects or len(reconnects) > 3 else OK
    return {"category": CAT, "name": name,
            "status": status, "detail": ", ".join(parts)}
  except (FileNotFoundError, subprocess.TimeoutExpired):
    return {"category": CAT, "name": name,
            "status": OK, "detail": "journalctl unavailable"}


def check_git_segments():
  # git segments are commit-driven, not clock-driven: absent on a quiet day is
  # normal, so WARN only when the freshest one is old enough to suggest a dead
  # poller (48h), not merely missing today. Timer liveness is check_services.
  files = list(SEGMENTS.glob("git-*.jsonl"))
  if not files:
    return {"category": CAT, "name": "segments/git", "status": WARN,
            "detail": "none"}
  age = file_age_minutes(max(files, key=lambda p: p.stat().st_mtime))
  status = WARN if age is not None and age > 48 * 60 else OK
  return {"category": CAT, "name": "segments/git freshness",
          "status": status, "detail": fmt_age(age)}


def main():
  results = check_services()
  results.extend(check_raw_freshness())
  results.extend(check_segments())
  results.append(check_git_segments())
  results.append(check_storage())
  results.append(check_watcher_journal())
  print(json.dumps(results))


if __name__ == "__main__":
  main()
