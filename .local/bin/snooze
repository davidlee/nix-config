#!/usr/bin/env bash

if [[ -n "$*" ]]; then
  TIME="$*"
elif [[ $(date +%H) -lt 7 ]]; then
  TIME="today 07:00"
else
  TIME="tomorrow 07:00"
fi

SEC=$(($(date -d "${TIME}" +%s) - $(date +%s)))

echo "Waking at $(date -d "${TIME}") (${SEC}s)"
sleep 3
rm /tmp/claude-snooze-on-stop 2>/dev/null || true
sudo rtcwake -m mem -s $SEC
